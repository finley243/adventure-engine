<data xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../schemas/areas.xsd">
    <area id="providence_lobby_entrance" room="providence_lobby">
        <name type="near">entrance</name>
        <link type="basic" dist="CLOSE" dir="N" area="providence_lobby_reception"/>
    </area>
    <area id="providence_lobby_reception" room="providence_lobby">
        <name type="near">reception desk</name>
        <link type="basic" dist="CLOSE" dir="S" area="providence_lobby_entrance"/>
        <link type="basic" dist="CLOSE" dir="N" area="providence_lobby_elevators"/>
        <link type="basic" dist="CLOSE" dir="E" area="providence_lobby_showroom"/>
        <object id="providence_lobby_reception_restroom_door" template="door_basic">
            <objectLink link="door_link" object="providence_lobby_restroom_door" dir="W"/>
        </object>
        <actor id="providence_receptionist" template="enemy_melee"/>
    </area>
    <area id="providence_lobby_elevators" room="providence_lobby">
        <name type="near" plural="true">elevators</name>
        <link type="basic" dist="CLOSE" dir="S" area="providence_lobby_reception"/>
    </area>
    <area id="providence_lobby_showroom">
        <name type="in">showroom</name>
        <link type="basic" dist="CLOSE" dir="W" area="providence_lobby_reception"/>
    </area>
    <area id="providence_lobby_restroom">
        <name type="in">restroom</name>
        <object id="providence_lobby_restroom_door" template="door_basic">
            <objectLink link="door_link" object="providence_lobby_reception_restroom_door" dir="E"/>
        </object>
    </area>
    <area id="warehouse_aisle_back">
        <name type="in">back aisle</name>
        <link type="basic" dist="CLOSE" dir="S" area="warehouse_aisle_front"/>
        <actor id="warehouse_enemy_1" template="enemy">
            <descriptor>greasy-haired</descriptor>
        </actor>
        <actor id="warehouse_enemy_2" template="enemy_melee">
            <descriptor>burly</descriptor>
        </actor>
    </area>
    <area id="warehouse_aisle_front">
        <name type="in">front aisle</name>
        <link type="basic" dist="CLOSE" dir="N" area="warehouse_aisle_back"/>
        <link type="basic" dist="CLOSE" dir="S" area="warehouse_bay_doors"/>
        <actor id="warehouse_enemy_3" template="enemy">
            <descriptor>tattooed</descriptor>
        </actor>
    </area>
    <area id="warehouse_bay_doors">
        <name type="near" plural="true">loading dock doors</name>
        <link type="basic" dist="CLOSE" dir="N" area="warehouse_aisle_front"/>
    </area>
    <area id="wilsons_corner_store_entrance" room="wilsons_corner_store">
        <name type="near">entrance</name>
        <link type="basic" dist="CLOSE" dir="N" area="wilsons_corner_store_shelves"/>
        <object id="wilsons_corner_store_door_exit" template="door_basic">
            <objectLink link="door_link" object="wilsons_corner_store_exterior_door" dir="SW"/>
        </object>
        <object id="wilsons_corner_store_counter" template="counter"/>
        <actor id="frank_wilson" template="frank_wilson">
            <behaviors>
                <behavior type="procedure" isCycle="true">
                    <behavior type="move" area="wilsons_corner_store_entrance" duration="6">
                        <idle>
                            <phrase>$actor {yawn$s|stretch$es|tap$s $actor's fingers rhythmically on the counter|look$s across the store|check$s something under the counter, then straighten$s back up|glance$s out the window}.</phrase>
                        </idle>
                    </behavior>
                    <behavior type="move" area="wilsons_corner_store_backroom_area" duration="1"/>
                </behavior>
            </behaviors>
        </actor>
    </area>
    <area id="wilsons_corner_store_shelves" room="wilsons_corner_store">
        <name type="near" plural="true">shelves</name>
        <description>
            <line>The coolers cast a cool white glow across the linoleum floor. The air is colder here than at the front of the store, and a low hum echoes off the walls.</line>
        </description>
        <link type="basic" dist="CLOSE" dir="S" area="wilsons_corner_store_entrance"/>
        <object id="wilsons_corner_store_shelf" template="store_shelf_snacks"/>
        <object id="wilsons_corner_store_cooler" template="store_cooler_soft_drinks"/>
        <object id="wilsons_corner_store_network_port" template="network_port">
            <networkID>wilsons_corner_store_main</networkID>
        </object>
        <object id="wilsons_corner_store_backroom_door" template="door_basic">
            <objectLink link="door_link" object="wilsons_corner_store_backroom_door_interior" dir="E"/>
        </object>
    </area>
    <area id="wilsons_corner_store_backroom_area">
        <name type="in">backroom</name>
        <object id="wilsons_corner_store_backroom_door_interior" template="door_basic">
            <objectLink link="door_link" object="wilsons_corner_store_backroom_door" dir="W"/>
        </object>
        <object id="wilsons_corner_store_backroom_exit" template="door_basic">
            <objectLink link="door_link" object="wilsons_corner_store_exterior_backroom_door" dir="E"/>
        </object>
    </area>
    <area id="archer_apartments_entrance_front" room="archer_apartments_entrance">
